# Example environment variables for Webscraping Agent
# Copy this file to `.env` and fill in the values.
# Example:
#   GROQ_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
#   GROQ_MODEL=llama-3.3-70b-versatile

# Your GROQ API key (required)
GROQ_API_KEY=your_groq_api_key_here

# Optional: model name to use with Groq
GROQ_MODEL=llama-3.3-70b-versatile

# Notes:
# - Place the real API key in `.env` (not in source control).
# - Get a key at: https://console.groq.com/keys